# Dockerfile for testing ROS 2 code examples across distros.
#
# Build args:
#   ROS_DISTRO  — humble | jazzy | rolling (default: jazzy)
#
# Usage:
#   docker build -f tests/Dockerfile.ros2-test --build-arg ROS_DISTRO=humble -t ros2-test:humble .
#   docker run --rm ros2-test:humble

ARG ROS_DISTRO=jazzy
FROM osrf/ros:${ROS_DISTRO}-desktop

# Re-declare ARG after FROM (Docker scoping rules)
ARG ROS_DISTRO
ENV ROS_DISTRO=${ROS_DISTRO}
ENV DEBIAN_FRONTEND=noninteractive
SHELL ["/bin/bash", "-c"]

# osrf/ros:*-desktop already includes pytest, colcon, rclcpp, rosidl, etc.
# Install ros2_control for hardware_interface package testing.
# Humble (22.04) pip doesn't support --break-system-packages; Jazzy+ (24.04) requires it.
# git/curl/python3-vcstool/python3-yaml are needed for the rolling-only
# source overlay below.
#
# On rolling we additionally upgrade every pre-baked `ros-rolling-*` package
# in the base image. Reason: the base image was built with an older rclcpp
# (and friends) baked in, but the newly-installed downstream packages
# (e.g. pal_statistics, diagnostic_updater, control_msgs, hardware_interface)
# have already been rebuilt against a newer rclcpp ABI on packages.ros.org.
# Without this upgrade, downstream link steps fail with "undefined reference
# to rclcpp::ok(...)" / "rclcpp::experimental::IntraProcessManager::..." —
# the new binaries reference symbols the old rclcpp doesn't export. The
# upgrade brings every pre-baked ROS apt package up to its current published
# version so the whole installed set is mutually consistent.
RUN apt-get update \
    && apt-get install -y --no-install-recommends python3-pytest python3-pip \
       git ca-certificates build-essential cmake curl \
       python3-vcstool python3-yaml \
       ros-${ROS_DISTRO}-hardware-interface \
       ros-${ROS_DISTRO}-ros2-control \
    && apt-get install -y \
       ros-${ROS_DISTRO}-rmw-cyclonedds-cpp \
    && if [ "${ROS_DISTRO}" = "rolling" ]; then \
         echo "[apt] upgrading pre-baked ros-rolling-* packages to current"; \
         pkgs=$(dpkg-query -W -f='${Package}\n' | grep '^ros-rolling-' || true); \
         if [ -n "$pkgs" ]; then \
           DEBIAN_FRONTEND=noninteractive apt-get install -y --only-upgrade $pkgs; \
         fi; \
       fi \
    && echo "[apt] verifying libddsc presence" \
    && ldconfig \
    && (ldconfig -p | grep -i libddsc || ls -la /opt/ros/${ROS_DISTRO}/lib/libdds* 2>/dev/null || echo "libddsc not found in standard paths") \
    && pip3 install hypothesis 2>/dev/null \
    || pip3 install --break-system-packages hypothesis \
    && rm -rf /var/lib/apt/lists/*

# Force Cyclone DDS as the RMW backend.
#
# Reason: our rolling overlay rebuilds rosidl_typesupport_fastrtps from
# upstream source on top of /opt/ros/rolling. The source HEAD's ABI does
# not necessarily match the apt-installed librmw_fastrtps_cpp.so, so
# dlopen(rmw_fastrtps_cpp) at runtime fails with `failed to load any RMW
# implementations`. Cyclone DDS uses a separate typesupport line
# (rosidl_typesupport_cyclonedds_cpp, not in our overlay) and is therefore
# unaffected. We set this for every distro because Cyclone DDS is Tier 1
# on humble / jazzy / rolling and the choice is behaviourally inert for
# our scaffold smoke tests.
ENV RMW_IMPLEMENTATION=rmw_cyclonedds_cpp

# Replace broken rolling binary CMake configs by source-overlaying their
# upstream source trees on top of /opt/ros/rolling.
#
# Why: as of late April 2026, `ros-rolling-control-msgs` (>= 6.9.0) and
# `ros-rolling-hardware-interface` (>= 6.7.0) were rebuilt against a new
# rosidl ABI that exports link-interface targets `rosidl_buffer::*` and
# `rosidl_buffer_backend::*`, but companion packages providing those
# targets are not yet released as standalone debs. The official
# `snapshots.ros.org` service does not publish the URL pattern apt
# expects for date-pinned rolling, so we cannot snapshot-pin reliably.
# Instead, we rebuild every package whose binary Config.cmake is broken
# from its current upstream source tree, in one workspace, so the new
# Config.cmake files reference each other consistently. The
# `--merge-install --install-base /opt/ros/rolling` flags overlay the
# regenerated cmake/ trees on top of the apt-installed tree.
#
# Sources:
#   * canonical ros2.repos manifest, filtered to repos with `rosidl` in
#     their name — supplies rosidl_buffer, rosidl_buffer_backend, and
#     every other rosidl sub-package the new ABI references.
#   * ros-controls/control_msgs — supplies the new control_msgs
#     Config.cmake compiled against the source rosidl.
#   * ros-controls/ros2_control — supplies the new hardware_interface
#     (plus controller_interface, transmission_interface, …)
#     Config.cmake compiled against the source control_msgs and rosidl.
#
# After overlay, verify that a downstream `find_package(hardware_interface)`
# resolves cleanly in a throwaway CMake project — if it does not, fail
# fast at this layer with the actionable error rather than later in the
# user-package build.
#
# Humble/Jazzy are no-ops here because their LTS apt repos are
# internally consistent.
RUN if [ "${ROS_DISTRO}" = "rolling" ]; then \
      set -e; \
      { source /opt/ros/${ROS_DISTRO}/setup.bash; } > /dev/null 2>&1; \
      echo "[overlay] ROS environment sourced"; \
      mkdir -p /tmp/overlay_ws/src; \
      cd /tmp/overlay_ws; \
      echo "[overlay] fetching ros2.repos"; \
      curl -fsSL https://raw.githubusercontent.com/ros2/ros2/rolling/ros2.repos -o ros2.repos; \
      python3 -c "import yaml; \
d = yaml.safe_load(open('ros2.repos')); \
keep = {k: v for k, v in d.get('repositories', {}).items() if 'rosidl' in k.lower() or 'ament_cmake' in k.lower()}; \
yaml.safe_dump({'repositories': keep}, open('rosidl.repos', 'w')); \
print('rosidl & ament_cmake repos:', list(keep.keys()))"; \
      echo "[overlay] vcs import"; \
      vcs import src < rosidl.repos; \
      echo "[overlay] cloning ros-controls repos"; \
      git clone --quiet --depth=1 https://github.com/ros-controls/ros2_control_cmake.git src/ros2_control_cmake; \
      git clone --quiet --depth=1 https://github.com/ros-controls/control_msgs.git src/control_msgs; \
      git clone --quiet --depth=1 https://github.com/ros-controls/ros2_control.git src/ros2_control; \
      echo "[overlay] packages staged in src/:"; \
      ls src; \
      echo "[overlay] colcon build (output redirected to /tmp/colcon.log; summary printed at end)"; \
      # --packages-up-to hardware_interface: we only need find_package(hardware_interface) \
      # to resolve in test_hw_pkg. Building controller_manager / ros2_control_node etc. \
      # exposes us to ABI mismatches in unrelated binary apt packages (e.g. \
      # libdiagnostic_updater rebuilt against unreleased rclcpp symbols). Limiting the \
      # build closes that surface entirely. \
      colcon build --merge-install \
        --install-base /opt/ros/${ROS_DISTRO} \
        --packages-up-to hardware_interface \
        --event-handlers console_direct- console_cohesion- console_start_end+ console_stderr+ status- summary+ \
        --cmake-args -DCMAKE_BUILD_TYPE=Release -DBUILD_TESTING=OFF \
        > /tmp/colcon.log 2>&1 \
        || { rc=$?; \
             echo "[overlay] colcon build FAILED (rc=$rc)"; \
             echo "=== last 300 lines of /tmp/colcon.log ==="; \
             tail -300 /tmp/colcon.log; \
             echo "=== per-package logs containing 'error' (tail -120 each) ==="; \
             for f in log/latest_build/*/stdout_stderr.log; do \
               [ -f "$f" ] && grep -liE '(^|[^a-z])error|cmake error|fatal' "$f" > /dev/null \
                 && { echo "--- $f ---"; tail -120 "$f"; }; \
             done; \
             exit "$rc"; }; \
      echo "[overlay] colcon build OK — last 30 lines of /tmp/colcon.log:"; \
      tail -30 /tmp/colcon.log; \
      rm -f /tmp/colcon.log; \
      cd / && rm -rf /tmp/overlay_ws; \
      echo "[overlay] verifying find_package(hardware_interface)"; \
      mkdir -p /tmp/fp_check && cd /tmp/fp_check; \
      printf 'cmake_minimum_required(VERSION 3.16)\nproject(fp_check LANGUAGES CXX)\nfind_package(hardware_interface REQUIRED)\nmessage(STATUS "hardware_interface OK")\n' > CMakeLists.txt; \
      cmake -S . -B build -DCMAKE_BUILD_TYPE=Release; \
      cd / && rm -rf /tmp/fp_check; \
      echo "[overlay] OK"; \
    fi

WORKDIR /ws/ros2-engineering-skills
COPY . .

# Stage 1: Pure-Python unit tests on the utility scripts
RUN python3 -m pytest tests/ -v --tb=short

# Stage 2: Scaffold packages (C++, Python, interfaces, hardware_interface)
RUN mkdir -p /ws/test_ws/src \
    && python3 scripts/create_package.py test_cpp_pkg --type cpp --dest /ws/test_ws/src \
    && python3 scripts/create_package.py test_py_pkg --type python --dest /ws/test_ws/src \
    && python3 scripts/create_package.py test_iface_pkg --type interfaces --dest /ws/test_ws/src \
    && python3 scripts/create_package.py test_hw_pkg --type hardware_interface --dest /ws/test_ws/src

# Stage 3: Build all scaffolded packages WITH testing enabled
# This compiles the generated gtest targets to verify the scaffolding is valid C++.
RUN source /opt/ros/${ROS_DISTRO}/setup.bash \
    && cd /ws/test_ws \
    && colcon build \
         --executor sequential \
         --event-handlers console_direct+ \
         --cmake-args -DCMAKE_BUILD_TYPE=Release

# Stage 4a: Run C++ and interfaces tests (CTest via colcon)
RUN source /opt/ros/${ROS_DISTRO}/setup.bash \
    && cd /ws/test_ws \
    && colcon test \
         --executor sequential \
         --event-handlers console_direct+ \
         --packages-select test_cpp_pkg test_iface_pkg test_hw_pkg \
    && colcon test-result --verbose

# Stage 4b: Run Python package tests with pytest directly
# (colcon test uses unittest runner for ament_python, which cannot discover pytest-style tests)
RUN source /opt/ros/${ROS_DISTRO}/setup.bash \
    && source /ws/test_ws/install/setup.bash \
    && cd /ws/test_ws/src/test_py_pkg \
    && python3 -m pytest test/ -v

# Stage 5: Validate generated launch files
RUN python3 scripts/launch_validator.py /ws/test_ws/src/test_cpp_pkg/launch/ \
    && python3 scripts/launch_validator.py /ws/test_ws/src/test_py_pkg/launch/

# Stage 6: QoS checker — all presets including safety_heartbeat with deadline/lifespan
RUN python3 scripts/qos_checker.py --preset sensor \
    && python3 scripts/qos_checker.py --preset command \
    && python3 scripts/qos_checker.py --preset map \
    && python3 scripts/qos_checker.py --preset diagnostics \
    && python3 scripts/qos_checker.py --preset parameter_events \
    && python3 scripts/qos_checker.py --preset action_feedback \
    && python3 scripts/qos_checker.py --preset safety_heartbeat

# Stage 7: Smoke-test — verify generated nodes actually start in ROS 2
RUN chmod +x tests/smoke_test_nodes.sh \
    && timeout 30 bash tests/smoke_test_nodes.sh

CMD echo "All tests passed for ROS 2 ${ROS_DISTRO}!"
