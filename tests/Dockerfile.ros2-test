# Dockerfile for testing ROS 2 code examples across distros.
#
# Build args:
#   ROS_DISTRO         — humble | jazzy | rolling (default: jazzy)
#   ROLLING_SNAPSHOT   — date-stamped snapshot to pin rolling apt against,
#                        format YYYY-MM-DD (default: 2026-04-23, the most
#                        recent date verified to predate the in-progress
#                        rosidl split that introduced unreleased
#                        rosidl_buffer / rosidl_buffer_backend CMake link
#                        targets in control_msgs and hardware_interface).
#                        Bump this once upstream ships a complete release
#                        of those packages alongside their consumers.
#
# Usage:
#   docker build -f tests/Dockerfile.ros2-test --build-arg ROS_DISTRO=humble -t ros2-test:humble .
#   docker run --rm ros2-test:humble

ARG ROS_DISTRO=jazzy
ARG ROLLING_SNAPSHOT=2026-04-23
FROM osrf/ros:${ROS_DISTRO}-desktop

# Re-declare ARGs after FROM (Docker scoping rules)
ARG ROS_DISTRO
ARG ROLLING_SNAPSHOT
ENV ROS_DISTRO=${ROS_DISTRO}
ENV ROLLING_SNAPSHOT=${ROLLING_SNAPSHOT}
ENV DEBIAN_FRONTEND=noninteractive
SHELL ["/bin/bash", "-c"]

# Pin the apt source on rolling to a known-good date snapshot.
#
# Why: `packages.ros.org/ros2/ubuntu` is a rolling pointer that is
# periodically inconsistent during multi-package refactors (e.g. the
# 2026-04-25 rosidl split rebuilt control_msgs and hardware_interface
# against rosidl_buffer / rosidl_buffer_backend, but those companion
# packages had not yet propagated as standalone debs — making
# `find_package(hardware_interface)` fail with "target was not found"
# at any consumer's CMake configure step). `snapshots.ros.org` mirrors
# packages.ros.org daily and lets us pick a date where the package set
# is internally consistent. Once upstream ships a coherent release we
# bump ROLLING_SNAPSHOT and the build moves forward — no other change
# is required.
#
# Humble/Jazzy use the rolling pointer normally because LTS distros
# do not undergo this kind of in-place refactor.
RUN if [ "${ROS_DISTRO}" = "rolling" ]; then \
      set -ex; \
      echo '--- apt source files before pinning ---'; \
      ls -la /etc/apt/sources.list.d/ || true; \
      # -R (capital) so symlinks like ros2.sources -> /usr/share/ros-apt-source/ros2.sources \
      # are followed during the recursive search. \
      files=$(grep -RlE 'packages\.ros\.org/ros2/ubuntu' /etc/apt/ 2>/dev/null || true); \
      if [ -z "$files" ]; then \
        echo "FATAL: no apt source file references packages.ros.org/ros2/ubuntu"; \
        echo "Contents of /etc/apt/sources.list.d/:"; \
        for f in /etc/apt/sources.list.d/*; do \
          [ -e "$f" ] && echo "--- $f ---" && cat "$f"; \
        done; \
        exit 1; \
      fi; \
      # Resolve symlinks to their underlying files and dedupe — sed -i on a \
      # symlink can replace the link with a regular file on some GNU sed \
      # versions, so always edit the real path. \
      real_files=$(for f in $files; do readlink -f "$f"; done | sort -u); \
      for f in $real_files; do \
        echo "Pinning $f to snapshot ${ROLLING_SNAPSHOT}"; \
        sed -i \
          -e "s|http://packages\.ros\.org/ros2/ubuntu|http://snapshots.ros.org/rolling/${ROLLING_SNAPSHOT}/ubuntu|g" \
          -e "s|https://packages\.ros\.org/ros2/ubuntu|http://snapshots.ros.org/rolling/${ROLLING_SNAPSHOT}/ubuntu|g" \
          "$f"; \
        echo "--- after pinning: $f ---"; \
        cat "$f"; \
      done; \
      echo '--- verifying pin took effect ---'; \
      if grep -RE 'packages\.ros\.org/ros2/ubuntu' /etc/apt/ /usr/share/ros-apt-source/ 2>/dev/null; then \
        echo "FATAL: still see packages.ros.org references after pinning"; \
        exit 1; \
      fi; \
      echo 'apt pin OK'; \
    fi

# osrf/ros:*-desktop already includes pytest, colcon, rclcpp, rosidl, etc.
# Install ros2_control for hardware_interface package testing.
# Humble (22.04) pip doesn't support --break-system-packages; Jazzy+ (24.04) requires it.
RUN apt-get update \
    && apt-get install -y --no-install-recommends python3-pytest python3-pip \
       ros-${ROS_DISTRO}-hardware-interface \
       ros-${ROS_DISTRO}-ros2-control \
    && pip3 install hypothesis 2>/dev/null \
    || pip3 install --break-system-packages hypothesis \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /ws/ros2-engineering-skills
COPY . .

# Stage 1: Pure-Python unit tests on the utility scripts
RUN python3 -m pytest tests/ -v --tb=short

# Stage 2: Scaffold packages (C++, Python, interfaces, hardware_interface)
RUN mkdir -p /ws/test_ws/src \
    && python3 scripts/create_package.py test_cpp_pkg --type cpp --dest /ws/test_ws/src \
    && python3 scripts/create_package.py test_py_pkg --type python --dest /ws/test_ws/src \
    && python3 scripts/create_package.py test_iface_pkg --type interfaces --dest /ws/test_ws/src \
    && python3 scripts/create_package.py test_hw_pkg --type hardware_interface --dest /ws/test_ws/src

# Stage 3: Build all scaffolded packages WITH testing enabled
# This compiles the generated gtest targets to verify the scaffolding is valid C++.
RUN source /opt/ros/${ROS_DISTRO}/setup.bash \
    && cd /ws/test_ws \
    && colcon build \
         --executor sequential \
         --event-handlers console_direct+ \
         --cmake-args -DCMAKE_BUILD_TYPE=Release

# Stage 4a: Run C++ and interfaces tests (CTest via colcon)
RUN source /opt/ros/${ROS_DISTRO}/setup.bash \
    && cd /ws/test_ws \
    && colcon test \
         --executor sequential \
         --event-handlers console_direct+ \
         --packages-select test_cpp_pkg test_iface_pkg test_hw_pkg \
    && colcon test-result --verbose

# Stage 4b: Run Python package tests with pytest directly
# (colcon test uses unittest runner for ament_python, which cannot discover pytest-style tests)
RUN source /opt/ros/${ROS_DISTRO}/setup.bash \
    && source /ws/test_ws/install/setup.bash \
    && cd /ws/test_ws/src/test_py_pkg \
    && python3 -m pytest test/ -v

# Stage 5: Validate generated launch files
RUN python3 scripts/launch_validator.py /ws/test_ws/src/test_cpp_pkg/launch/ \
    && python3 scripts/launch_validator.py /ws/test_ws/src/test_py_pkg/launch/

# Stage 6: QoS checker — all presets including safety_heartbeat with deadline/lifespan
RUN python3 scripts/qos_checker.py --preset sensor \
    && python3 scripts/qos_checker.py --preset command \
    && python3 scripts/qos_checker.py --preset map \
    && python3 scripts/qos_checker.py --preset diagnostics \
    && python3 scripts/qos_checker.py --preset parameter_events \
    && python3 scripts/qos_checker.py --preset action_feedback \
    && python3 scripts/qos_checker.py --preset safety_heartbeat

# Stage 7: Smoke-test — verify generated nodes actually start in ROS 2
RUN chmod +x tests/smoke_test_nodes.sh \
    && timeout 30 bash tests/smoke_test_nodes.sh

CMD echo "All tests passed for ROS 2 ${ROS_DISTRO}!"
